rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelfUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function signedInEmail() {
      return (isSignedIn() && request.auth.token.email is string)
        ? request.auth.token.email
        : "";
    }

    function signedInEmailLower() {
      return signedInEmail().lower();
    }

    function signedInEmailMatches(emailValue) {
      return isSignedIn()
        && emailValue is string
        && emailValue.lower() == signedInEmailLower();
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyChanged(allowed) {
      return changedKeys().hasOnly(allowed);
    }

    function isPersonalWorkspaceId(workspaceId, uid) {
      return workspaceId == "personal_" + uid;
    }

    function isWorkspaceOwnerByDoc(workspaceId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == uid;
    }

    function hasWorkspaceMemberDoc(workspaceId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid));
    }

    function memberData(workspaceId, uid) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data;
    }

    function hasLegacyEmailMemberDoc(workspaceId, emailValue) {
      return isSignedIn()
        && emailValue is string
        && emailValue != ""
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(emailValue));
    }

    function legacyEmailMemberData(workspaceId, emailValue) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(emailValue)).data;
    }

    function legacyEmailMemberMatchesSignedIn(workspaceId, emailValue) {
      return hasLegacyEmailMemberDoc(workspaceId, emailValue)
        && legacyEmailMemberData(workspaceId, emailValue).status == "active"
        && legacyEmailMemberData(workspaceId, emailValue).workspaceId == workspaceId
        && legacyEmailMemberData(workspaceId, emailValue).role in ["admin", "member", "viewer"]
        && (
          (
            "email" in legacyEmailMemberData(workspaceId, emailValue)
            && signedInEmailMatches(legacyEmailMemberData(workspaceId, emailValue).email)
          )
          || (
            "emailLower" in legacyEmailMemberData(workspaceId, emailValue)
            && signedInEmailMatches(legacyEmailMemberData(workspaceId, emailValue).emailLower)
          )
          || (
            "email_lowercase" in legacyEmailMemberData(workspaceId, emailValue)
            && signedInEmailMatches(legacyEmailMemberData(workspaceId, emailValue).email_lowercase)
          )
          || (
            "emailAddress" in legacyEmailMemberData(workspaceId, emailValue)
            && signedInEmailMatches(legacyEmailMemberData(workspaceId, emailValue).emailAddress)
          )
        );
    }

    function isTrustedActiveWorkspaceMemberDoc(workspaceId, uid) {
      return hasWorkspaceMemberDoc(workspaceId, uid)
        && memberData(workspaceId, uid).status == "active"
        && memberData(workspaceId, uid).role in ["owner", "admin", "member", "viewer"]
        && (
          !("workspaceId" in memberData(workspaceId, uid))
          || memberData(workspaceId, uid).workspaceId == workspaceId
        );
    }

    function isActiveWorkspaceMember(workspaceId, uid) {
      return isSignedIn()
        && (
          isWorkspaceOwnerByDoc(workspaceId, uid)
          || isTrustedActiveWorkspaceMemberDoc(workspaceId, uid)
        );
    }

    function workspaceRole(workspaceId, uid) {
      return isWorkspaceOwnerByDoc(workspaceId, uid)
        ? "owner"
        : (
          isTrustedActiveWorkspaceMemberDoc(workspaceId, uid)
            ? memberData(workspaceId, uid).role
            : "viewer"
        );
    }

    function isWorkspaceOwnerOrAdmin(workspaceId) {
      return isSignedIn()
        && (
          isWorkspaceOwnerByDoc(workspaceId, request.auth.uid)
          || (
            isTrustedActiveWorkspaceMemberDoc(workspaceId, request.auth.uid)
            && memberData(workspaceId, request.auth.uid).role in ["owner", "admin"]
          )
        );
    }

    function canEditWorkspaceContent(workspaceId) {
      return isSignedIn()
        && isWorkspaceOwnerOrAdmin(workspaceId);
    }

    function canCommentInWorkspace(workspaceId) {
      return isSignedIn()
        && (
          isWorkspaceOwnerOrAdmin(workspaceId)
          || (
            isTrustedActiveWorkspaceMemberDoc(workspaceId, request.auth.uid)
            && memberData(workspaceId, request.auth.uid).role == "member"
          )
        );
    }

    function isWorkspaceViewerOnly(workspaceId) {
      return isSignedIn()
        && isTrustedActiveWorkspaceMemberDoc(workspaceId, request.auth.uid)
        && memberData(workspaceId, request.auth.uid).role == "viewer";
    }

    function inviteStatusAllowsJoin(inviteData) {
      return !("status" in inviteData)
        || inviteData.status in ["pending", "active", "accepted", "invited"];
    }

    function hasWorkspaceInviteDoc(workspaceId, inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode));
    }

    function hasGlobalInviteDoc(inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && exists(/databases/$(database)/documents/invites/$(inviteCode));
    }

    function hasValidWorkspaceInvite(workspaceId, inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && (
          (
            hasWorkspaceInviteDoc(workspaceId, inviteCode)
            && get(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode)).data.workspaceId == workspaceId
            && inviteStatusAllowsJoin(get(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode)).data)
          )
          || (
            hasGlobalInviteDoc(inviteCode)
            && get(/databases/$(database)/documents/invites/$(inviteCode)).data.workspaceId == workspaceId
            && inviteStatusAllowsJoin(get(/databases/$(database)/documents/invites/$(inviteCode)).data)
          )
        );
    }

    function inviteEmailMatchesSignedIn(inviteData) {
      return isSignedIn()
        && (
          (
            inviteData.email is string
            && signedInEmailMatches(inviteData.email)
          )
          || (
            inviteData.emailLower is string
            && signedInEmailMatches(inviteData.emailLower)
          )
          || (
            inviteData.email_lowercase is string
            && signedInEmailMatches(inviteData.email_lowercase)
          )
          || (
            inviteData.invitedEmail is string
            && signedInEmailMatches(inviteData.invitedEmail)
          )
          || (
            inviteData.invitedEmailLower is string
            && signedInEmailMatches(inviteData.invitedEmailLower)
          )
          || (
            inviteData.acceptedByEmail is string
            && signedInEmailMatches(inviteData.acceptedByEmail)
          )
          || (
            inviteData.acceptedByEmailLower is string
            && signedInEmailMatches(inviteData.acceptedByEmailLower)
          )
          || (
            inviteData.acceptedByUid is string
            && inviteData.acceptedByUid == request.auth.uid
          )
          || (
            inviteData.acceptedBy is string
            && inviteData.acceptedBy == request.auth.uid
          )
        );
    }

    function inviteAcceptUpdateAllowed() {
      return isSignedIn()
        && (
          inviteEmailMatchesSignedIn(resource.data)
          || inviteEmailMatchesSignedIn(request.resource.data)
          || request.resource.data.acceptedByUid == request.auth.uid
          || request.resource.data.acceptedBy == request.auth.uid
        );
    }

    function isProjectOwner(projectData) {
      return isSignedIn()
        && (
          (projectData.ownerId is string && projectData.ownerId == request.auth.uid)
          || (projectData.uid is string && projectData.uid == request.auth.uid)
          || (projectData.createdBy is string && projectData.createdBy == request.auth.uid)
        );
    }

    function isProjectPrivate(projectData) {
      return projectData.visibility == "private"
        || projectData.projectScope == "private"
        || projectData.isPrivateProject == true;
    }

    function isRootProjectCollaborator(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
    }

    function rootProjectVisibleToMe(projectData, projectId) {
      return isSignedIn()
        && (
          isProjectOwner(projectData)
          || isRootProjectCollaborator(projectId)
          || (
            projectData.workspaceId is string
            && projectData.visibility == "workspace"
            && isActiveWorkspaceMember(projectData.workspaceId, request.auth.uid)
          )
        );
    }

    function canWorkspaceAdminRemoveUser(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && resource.data.workspaceId is string
        && request.resource.data.lastRemovedFromWorkspaceId == resource.data.workspaceId
        && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
        && isActiveWorkspaceMember(resource.data.workspaceId, userId)
        && request.resource.data.workspaceId == request.resource.data.personalWorkspaceId
        && onlyChanged([
          "workspaceId",
          "personalWorkspaceId",
          "lastRemovedFromWorkspaceId",
          "removedFromWorkspaceAt",
          "updatedAt"
        ]);
    }

    // GLOBAL: a comment is readable by a guest if the comment itself carries
    // the lowercased list of emails the parent task is shared with, and the
    // signed-in user's email is in that list. collectionGroup rules cannot
    // get() the parent task, so the task's share list must be stamped on each
    // comment at write time (sharedEmailsLower).
        function commentVisibleToSignedInGuest() {
      return signedInEmailLower() != ""
        && (
          (
            resource.data.sharedEmailsLower is list
            && signedInEmailLower() in resource.data.sharedEmailsLower
          )
          || (
            resource.data.authorEmail is string
            && resource.data.authorEmail.lower() == signedInEmailLower()
          )
        );
    }


    match /invites/{inviteCode} {
      allow read: if true;

      allow create: if isSignedIn();

      allow update: if isSignedIn()
        && (
          inviteAcceptUpdateAllowed()
          || (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
        );

      allow delete: if isSignedIn()
        && (
          (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
          || resource.data.invitedBy == request.auth.uid
          || resource.data.invitedByUid == request.auth.uid
        );
    }

    match /{path=**}/collaborators/{collaboratorId} {
      allow get: if isSignedIn()
        && (
          collaboratorId == request.auth.uid
          || resource.data.uid == request.auth.uid
          || resource.data.userId == request.auth.uid
        );

      allow list: if isSignedIn();

      allow create, update, delete: if isSignedIn();
    }

    match /{path=**}/shares/{shareId} {
      allow list, get: if isSignedIn()
        && (
          (resource.data.sharedByUid is string && resource.data.sharedByUid == request.auth.uid)
          || (resource.data.invitedBy is string && resource.data.invitedBy == request.auth.uid)
          || (resource.data.acceptedByUid is string && resource.data.acceptedByUid == request.auth.uid)
          || (resource.data.acceptedBy is string && resource.data.acceptedBy == request.auth.uid)

          || (
            resource.data.sharedWithEmail is string
            && signedInEmailMatches(resource.data.sharedWithEmail)
          )
          || (
            resource.data.sharedWithEmailLower is string
            && signedInEmailMatches(resource.data.sharedWithEmailLower)
          )
          || (
            resource.data.invitedEmail is string
            && signedInEmailMatches(resource.data.invitedEmail)
          )
          || (
            resource.data.invitedEmailLower is string
            && signedInEmailMatches(resource.data.invitedEmailLower)
          )
          || (
            resource.data.acceptedByEmail is string
            && signedInEmailMatches(resource.data.acceptedByEmail)
          )
          || (
            resource.data.acceptedByEmailLower is string
            && signedInEmailMatches(resource.data.acceptedByEmailLower)
          )

          || (
            resource.data.workspaceId is string
            && isActiveWorkspaceMember(resource.data.workspaceId, request.auth.uid)
          )
        );
    }

    // ============================================================
    // GLOBAL: collection-group READ rule for the Conversations feed.
    // useConversations runs collectionGroup('comments'), which CANNOT use
    // the per-task comment rule (that rule calls get() on the parent task,
    // which is forbidden for collection-group queries and causes the
    // permission-denied flash). This rule is satisfiable from the comment
    // doc's OWN fields only, so the collection-group query succeeds.
    //
    // REQUIRED on the client: the query MUST include
    //   where('workspaceId', '==', currentWorkspaceId)
    // and every comment doc MUST carry sharedEmailsLower for guest reads.
    // Read-only (list/get) — no writes are granted here.
    // ============================================================
    function commentTaskGuestShareData(workspaceId, taskId, shareId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)/shares/$(shareId)).data;
    }

    function commentTaskGuestShareExists(workspaceId, taskId, shareId) {
      return shareId is string
        && shareId != ""
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)/shares/$(shareId));
    }

    match /{path=**}/comments/{commentId} {
      allow list, get: if isSignedIn()
        && resource.data.workspaceId is string
        && (
          isActiveWorkspaceMember(resource.data.workspaceId, request.auth.uid)
          || (resource.data.authorId is string && resource.data.authorId == request.auth.uid)
          || isPersonalWorkspaceId(resource.data.workspaceId, request.auth.uid)
          || commentVisibleToSignedInGuest()
                    || (
            resource.data.taskId is string
            && resource.data.taskId != ""
            && resource.data.guestShareId is string
            && resource.data.guestShareId != ""
            && commentTaskGuestShareExists(
                 resource.data.workspaceId,
                 resource.data.taskId,
                 resource.data.guestShareId
               )
            && commentTaskGuestShareData(
                 resource.data.workspaceId,
                 resource.data.taskId,
                 resource.data.guestShareId
               ).status in ["active", "accepted"]
            && (
              commentTaskGuestShareData(
                resource.data.workspaceId,
                resource.data.taskId,
                resource.data.guestShareId
              ).acceptedByUid == request.auth.uid
              || commentTaskGuestShareData(
                resource.data.workspaceId,
                resource.data.taskId,
                resource.data.guestShareId
              ).acceptedBy == request.auth.uid
            )
          )

        );
    }

    match /projects/{projectId} {
      allow get: if rootProjectVisibleToMe(resource.data, projectId);

      allow list: if rootProjectVisibleToMe(resource.data, projectId);

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (
          !("ownerId" in request.resource.data)
          || request.resource.data.ownerId == request.auth.uid
        )
        && (
          !("uid" in request.resource.data)
          || request.resource.data.uid == request.auth.uid
        );

      allow update: if isSignedIn()
        && (
          isProjectOwner(resource.data)
          || (
            resource.data.workspaceId is string
            && canEditWorkspaceContent(resource.data.workspaceId)
          )
        );

      allow delete: if isSignedIn()
        && (
          isProjectOwner(resource.data)
          || (
            resource.data.workspaceId is string
            && canEditWorkspaceContent(resource.data.workspaceId)
          )
        );

      match /invites/{inviteCode} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /collaborators/{uid} {
        allow read: if isSignedIn()
          && (
            uid == request.auth.uid
            || isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
          );

        allow write: if isSignedIn()
          && (
            uid == request.auth.uid
            || isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
          );
      }

      match /tasks/{taskId} {
        allow read: if isSignedIn()
          && rootProjectVisibleToMe(
            get(/databases/$(database)/documents/projects/$(projectId)).data,
            projectId
          );

        allow create, update, delete: if isSignedIn()
          && (
            isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
            || (
              get(/databases/$(database)/documents/projects/$(projectId)).data.workspaceId is string
              && canEditWorkspaceContent(get(/databases/$(database)/documents/projects/$(projectId)).data.workspaceId)
            )
          );

        match /{document=**} {
          allow read: if isSignedIn()
            && rootProjectVisibleToMe(
              get(/databases/$(database)/documents/projects/$(projectId)).data,
              projectId
            );

          allow write: if isSignedIn()
            && (
              isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
              || (
                get(/databases/$(database)/documents/projects/$(projectId)).data.workspaceId is string
                && canEditWorkspaceContent(get(/databases/$(database)/documents/projects/$(projectId)).data.workspaceId)
              )
            );
        }
      }
    }

    match /workspaces/{workspaceId} {
      function workspaceOwnerId() {
        return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId;
      }

      function isWorkspaceOwner() {
        return isSignedIn() && workspaceOwnerId() == request.auth.uid;
      }

      function isEditingCanonicalOwner(memberId) {
        return memberId == workspaceOwnerId();
      }

      function workspaceProjectVisibleToMe(projectData) {
        return isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              && (
                !isProjectPrivate(projectData)
                || isProjectOwner(projectData)
                || (
                  projectData.memberIds is list
                  && request.auth.uid in projectData.memberIds
                )
                || (
                  projectData.collaboratorUids is list
                  && request.auth.uid in projectData.collaboratorUids
                )
              )
            )
          );
      }

      function canManageWorkspaceProject(projectData) {
        return isSignedIn()
          && (
            canEditWorkspaceContent(workspaceId)
            || (
              isProjectPrivate(projectData)
              && isProjectOwner(projectData)
            )
          );
      }

      allow get: if isSignedIn()
        && (
          isActiveWorkspaceMember(workspaceId, request.auth.uid)
          || hasWorkspaceMemberDoc(workspaceId, request.auth.uid)
          || isPersonalWorkspaceId(workspaceId, request.auth.uid)
          || resource.data.ownerId == request.auth.uid
        );

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && (
          request.resource.data.workspaceId == workspaceId
          || request.resource.data.id == workspaceId
        );

      allow update: if isSignedIn()
        && (
          isWorkspaceOwnerOrAdmin(workspaceId)
          || (
            isPersonalWorkspaceId(workspaceId, request.auth.uid)
            && resource.data.ownerId == request.auth.uid
          )
          || (
            hasWorkspaceMemberDoc(workspaceId, request.auth.uid)
            && onlyChanged([
              "memberCount",
              "usedSeats",
              "updatedAt",
              "lastJoinedAt"
            ])
          )
        );

      allow delete: if isSignedIn()
        && isWorkspaceOwnerByDoc(workspaceId, request.auth.uid);

      match /members/{memberId} {
        allow get: if isSignedIn()
          && (
            memberId == request.auth.uid
            || memberId == signedInEmailLower()
            || memberId == signedInEmail()
            || isActiveWorkspaceMember(workspaceId, request.auth.uid)
            || isWorkspaceOwnerOrAdmin(workspaceId)
          );

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isPersonalWorkspaceId(workspaceId, request.auth.uid)
              && memberId == request.auth.uid
              && request.resource.data.workspaceId == workspaceId
              && request.resource.data.status == "active"
              && request.resource.data.role == "owner"
              && (
                request.resource.data.uid == request.auth.uid
                || request.resource.data.userId == request.auth.uid
              )
            )
            || (
              memberId == request.auth.uid
              && request.resource.data.workspaceId == workspaceId
              && request.resource.data.status == "active"
              && request.resource.data.role in ["admin", "member", "viewer"]
              && (
                request.resource.data.uid == request.auth.uid
                || request.resource.data.userId == request.auth.uid
              )
              && (
                hasValidWorkspaceInvite(workspaceId, request.resource.data.inviteCode)
                || hasValidWorkspaceInvite(workspaceId, request.resource.data.acceptedInviteCode)
                || hasValidWorkspaceInvite(workspaceId, request.resource.data.code)
              )
            )
            || (
              memberId == request.auth.uid
              && legacyEmailMemberMatchesSignedIn(workspaceId, signedInEmailLower())
              && request.resource.data.workspaceId == workspaceId
              && request.resource.data.status == "active"
              && request.resource.data.role == legacyEmailMemberData(workspaceId, signedInEmailLower()).role
              && (
                request.resource.data.uid == request.auth.uid
                || request.resource.data.userId == request.auth.uid
              )
            )
            || (
              memberId == request.auth.uid
              && legacyEmailMemberMatchesSignedIn(workspaceId, signedInEmail())
              && request.resource.data.workspaceId == workspaceId
              && request.resource.data.status == "active"
              && request.resource.data.role == legacyEmailMemberData(workspaceId, signedInEmail()).role
              && (
                request.resource.data.uid == request.auth.uid
                || request.resource.data.userId == request.auth.uid
              )
            )
          );

        allow update: if isSignedIn()
          && (
            (
              memberId == request.auth.uid
              && request.resource.data.role == resource.data.role
              && request.resource.data.status == resource.data.status
              && request.resource.data.workspaceId == resource.data.workspaceId
              && (
                !("permissions" in resource.data)
                || request.resource.data.permissions == resource.data.permissions
              )
              && onlyChanged([
                "displayName",
                "name",
                "email",
                "emailLower",
                "email_lowercase",
                "photoURL",
                "avatar",
                "avatarColor",
                "avatarUrl",
                "avatarURL",
                "googlePhotoURL",
                "lastActive",
                "updatedAt"
              ])
            )
            || (
              isWorkspaceOwnerOrAdmin(workspaceId)
              && (
                !isEditingCanonicalOwner(memberId)
                || isWorkspaceOwner()
              )
            )
          );

        allow delete: if isSignedIn()
          && (
            (
              memberId == request.auth.uid
              && workspaceOwnerId() != request.auth.uid
            )
            || (
              isWorkspaceOwnerOrAdmin(workspaceId)
              && !isEditingCanonicalOwner(memberId)
            )
          );
      }

      match /people/{personId} {
        function isGuestPersonId() {
          return personId.matches("^guest_.*");
        }

        function incomingDocBelongsToSignedInUser() {
          return isSignedIn()
            && request.resource.data.emailLower is string
            && signedInEmailMatches(request.resource.data.emailLower);
        }

        function existingDocBelongsToSignedInUser() {
          return isSignedIn()
            && resource.data.emailLower is string
            && signedInEmailMatches(resource.data.emailLower);
        }

        allow read: if isSignedIn()
          && (
            personId == request.auth.uid
            || isActiveWorkspaceMember(workspaceId, request.auth.uid)
            || isWorkspaceOwnerOrAdmin(workspaceId)
            || existingDocBelongsToSignedInUser()
          );

        allow create: if isSignedIn()
          && (
            personId == request.auth.uid
            || isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isGuestPersonId()
              && incomingDocBelongsToSignedInUser()
            )
          );

        allow update: if isSignedIn()
          && (
            personId == request.auth.uid
            || isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isGuestPersonId()
              && existingDocBelongsToSignedInUser()
            )
          );

        allow delete: if isSignedIn()
          && (
            personId == request.auth.uid
            || isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isGuestPersonId()
              && existingDocBelongsToSignedInUser()
            )
          );
      }

      match /invites/{inviteCode} {
        allow read: if true;

        allow create: if isSignedIn()
          && isWorkspaceOwnerOrAdmin(workspaceId);

        allow update: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              resource.data.workspaceId == workspaceId
              && (
                inviteAcceptUpdateAllowed()
                || request.resource.data.acceptedByUid == request.auth.uid
                || request.resource.data.acceptedBy == request.auth.uid
              )
            )
            || (
              hasValidWorkspaceInvite(workspaceId, inviteCode)
              && request.resource.data.acceptedByUid == request.auth.uid
            )
          );

        allow delete: if isSignedIn()
          && isWorkspaceOwnerOrAdmin(workspaceId);
      }

      match /projects/{projectId} {
        allow get: if workspaceProjectVisibleToMe(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.createdBy == request.auth.uid
          && (
            !("ownerId" in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid
          )
          && (
            !("uid" in request.resource.data)
            || request.resource.data.uid == request.auth.uid
          )
          && (
            canEditWorkspaceContent(workspaceId)
            || (
              isPersonalWorkspaceId(workspaceId, request.auth.uid)
              && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
              && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid
            )
          );

        allow update: if isSignedIn()
          && canManageWorkspaceProject(resource.data);

        allow delete: if isSignedIn()
          && canManageWorkspaceProject(resource.data);

        match /{document=**} {
          allow read: if isSignedIn()
            && workspaceProjectVisibleToMe(
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data
            );

          allow write: if isSignedIn()
            && canManageWorkspaceProject(
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data
            );
        }
      }

      match /tasks/{taskId} {
        function taskSharedWithSignedInEmail(taskData) {
          return isSignedIn()
            && taskData != null
            && taskData.sharedWithEmails is list
            && (
              signedInEmail() in taskData.sharedWithEmails
              || signedInEmailLower() in taskData.sharedWithEmails
              || signedInEmail().lower() in taskData.sharedWithEmails
            );
        }

        function canReadTaskData(taskData) {
          return isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || taskSharedWithSignedInEmail(taskData)
            );
        }

        function canReadCurrentTask() {
          return canReadTaskData(
            get(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)).data
          );
        }

        function currentTaskSharedWithSignedInEmail() {
          return taskSharedWithSignedInEmail(
            get(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)).data
          );
        }

        function canCommentOnCurrentTask() {
          return canCommentInWorkspace(workspaceId)
            || currentTaskSharedWithSignedInEmail();
        }

        function guestShareDocPath(shareId) {
          return /databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)/shares/$(shareId);
        }

        function shareDocMarksViewer(shareData) {
          return shareData != null
            && shareData.guestRole == "viewer"
            && (
              (shareData.invitedEmailLower is string && signedInEmailMatches(shareData.invitedEmailLower))
              || (shareData.invitedEmail is string && signedInEmailMatches(shareData.invitedEmail))
              || (shareData.sharedWithEmail is string && signedInEmailMatches(shareData.sharedWithEmail))
              || (shareData.sharedWithEmailLower is string && signedInEmailMatches(shareData.sharedWithEmailLower))
              || (shareData.acceptedByEmail is string && signedInEmailMatches(shareData.acceptedByEmail))
              || (shareData.acceptedByEmailLower is string && signedInEmailMatches(shareData.acceptedByEmailLower))
              || (shareData.acceptedByUid is string && shareData.acceptedByUid == request.auth.uid)
              || (shareData.acceptedBy is string && shareData.acceptedBy == request.auth.uid)
            );
        }

        function signedInGuestIsViewerForShare(shareId) {
          return isSignedIn()
            && shareId is string
            && shareId != ""
            && exists(guestShareDocPath(shareId))
            && shareDocMarksViewer(get(guestShareDocPath(shareId)).data);
        }

        function shareBelongsToSignedInEmail(shareData) {
          return isSignedIn()
            && shareData != null
            && (
              (shareData.sharedWithEmail is string && signedInEmailMatches(shareData.sharedWithEmail))
              || (shareData.sharedWithEmailLower is string && signedInEmailMatches(shareData.sharedWithEmailLower))
              || (shareData.invitedEmail is string && signedInEmailMatches(shareData.invitedEmail))
              || (shareData.invitedEmailLower is string && signedInEmailMatches(shareData.invitedEmailLower))
              || (shareData.acceptedByEmail is string && signedInEmailMatches(shareData.acceptedByEmail))
              || (shareData.acceptedByEmailLower is string && signedInEmailMatches(shareData.acceptedByEmailLower))
              || (shareData.acceptedByUid is string && shareData.acceptedByUid == request.auth.uid)
              || (shareData.acceptedBy is string && shareData.acceptedBy == request.auth.uid)
            );
        }

        function shareOwnerIsSignedInUser(shareData) {
          return isSignedIn()
            && (
              shareData.sharedByUid == request.auth.uid
              || shareData.invitedBy == request.auth.uid
            );
        }

        function shareSelfRemovalAllowed() {
          return isSignedIn()
            && shareBelongsToSignedInEmail(resource.data)
            && request.resource.data.status == "removed"
            && onlyChanged([
              "status",
              "removedByUid",
              "removedByEmail",
              "removedByEmailLower",
              "removedAt",
              "updatedAt"
            ]);
        }

        allow get: if canReadTaskData(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && canEditWorkspaceContent(workspaceId)
          && request.resource.data.workspaceId == workspaceId;

        allow update, delete: if isSignedIn()
          && canEditWorkspaceContent(workspaceId);

        match /shares/{shareId} {
          allow get: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || canReadCurrentTask()
              || shareBelongsToSignedInEmail(resource.data)
              || shareOwnerIsSignedInUser(resource.data)
            );

          allow list: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || canReadCurrentTask()
            );

          allow create: if isSignedIn()
            && canEditWorkspaceContent(workspaceId)
            && (
              request.resource.data.sharedByUid == request.auth.uid
              || request.resource.data.invitedBy == request.auth.uid
            );

          allow update: if isSignedIn()
            && (
              canEditWorkspaceContent(workspaceId)
              || shareOwnerIsSignedInUser(resource.data)
              || isWorkspaceOwnerByDoc(workspaceId, request.auth.uid)
              || shareSelfRemovalAllowed()
              || (
                shareBelongsToSignedInEmail(resource.data)
                && (resource.data.status == "pending" || resource.data.status == "active")
                && request.resource.data.status == "active"
                && request.resource.data.acceptedByUid == request.auth.uid
                && (
                  request.resource.data.acceptedByEmail == request.auth.token.email
                  || request.resource.data.acceptedByEmailLower == signedInEmailLower()
                )
                && onlyChanged([
                  "status",
                  "acceptedBy",
                  "acceptedByUid",
                  "acceptedByEmail",
                  "acceptedByEmailLower",
                  "acceptedByName",
                  "acceptedByPhotoURL",
                  "acceptedAt",
                  "invitedEmailLower",
                  "updatedAt"
                ])
              )
            );

          allow delete: if isSignedIn()
            && (
              canEditWorkspaceContent(workspaceId)
              || shareOwnerIsSignedInUser(resource.data)
              || isWorkspaceOwnerByDoc(workspaceId, request.auth.uid)
              || shareBelongsToSignedInEmail(resource.data)
            );
        }

               match /comments/{commentId} {
          // GLOBAL: a participant can read in-task comments if they can read
          // the parent task (member or sharedWithEmails) OR the comment itself
          // carries them in sharedEmailsLower OR they authored it. This mirrors
          // the collection-group rule so the in-task listener never gets a
          // permission-denied when the parent task's sharedWithEmails is stale.
          allow read: if canReadCurrentTask()
            || (
              resource.data.sharedEmailsLower is list
              && signedInEmailLower() != ""
              && signedInEmailLower() in resource.data.sharedEmailsLower
            )
            || (
              resource.data.authorEmail is string
              && signedInEmailLower() != ""
              && resource.data.authorEmail.lower() == signedInEmailLower()
            )
            || (
              resource.data.authorId is string
              && resource.data.authorId == request.auth.uid
            );


          allow create: if canReadCurrentTask()
            && (
              canEditWorkspaceContent(workspaceId)
              || (
                isTrustedActiveWorkspaceMemberDoc(workspaceId, request.auth.uid)
                && memberData(workspaceId, request.auth.uid).role == "member"
              )
              || (
                currentTaskSharedWithSignedInEmail()
                && (
                  !("guestShareId" in request.resource.data)
                  || request.resource.data.guestShareId == ""
                  || !signedInGuestIsViewerForShare(request.resource.data.guestShareId)
                )
              )
            )
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.taskId == taskId;

          allow update: if canReadCurrentTask()
            && (
              resource.data.authorId == request.auth.uid
              || canEditWorkspaceContent(workspaceId)
            );

          allow delete: if canReadCurrentTask()
            && (
              resource.data.authorId == request.auth.uid
              || canEditWorkspaceContent(workspaceId)
            );
        }

        match /likes/{likeId} {
          allow read: if canReadCurrentTask();

          allow create, update, delete: if canReadCurrentTask()
            && request.auth.uid == likeId;
        }

        match /{document=**} {
          allow read: if isSignedIn()
            && isActiveWorkspaceMember(workspaceId, request.auth.uid);

          allow write: if isSignedIn()
            && canEditWorkspaceContent(workspaceId);
        }
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSelfUid(userId);

      allow update: if isSelfUid(userId)
        || canWorkspaceAdminRemoveUser(userId);

      allow delete: if isSelfUid(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelfUid(userId);

        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid == userId;
      }

      match /projects/{projectId} {
        allow read, write: if isSelfUid(userId);

        match /{document=**} {
          allow read, write: if isSelfUid(userId);
        }
      }

      match /tasks/{taskId} {
        allow read, create, update, delete: if isSelfUid(userId);

        match /comments/{commentId} {
          allow read, create, update, delete: if isSelfUid(userId);
        }

        match /{document=**} {
          allow read, write: if isSelfUid(userId);
        }
      }

      match /{subcollection}/{docId} {
        allow read, write: if isSelfUid(userId);
      }
    }
  }
}
