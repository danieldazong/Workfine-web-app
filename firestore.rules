rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelfUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function signedInEmailLower() {
      return isSignedIn() && request.auth.token.email_lowercase is string
        ? request.auth.token.email_lowercase
        : signedInEmail();
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyChanged(allowed) {
      return changedKeys().hasOnly(allowed);
    }

    function isActiveWorkspaceMember(workspaceId, uid) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid))
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.status == "active";
    }

    function isWorkspaceOwnerOrAdmin(workspaceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.status == "active"
        && (
          get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == "owner" ||
          get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isProjectCollaborator(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
    }

    function isProjectOwner(projectData) {
      return isSignedIn()
        && (
          (projectData.ownerId is string && projectData.ownerId == request.auth.uid) ||
          (projectData.uid is string && projectData.uid == request.auth.uid)
        );
    }

    function canWorkspaceAdminReadUser(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && resource.data.workspaceId is string
        && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
        && isActiveWorkspaceMember(resource.data.workspaceId, userId);
    }

    function canWorkspaceAdminRemoveUser(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && resource.data.workspaceId is string
        && request.resource.data.lastRemovedFromWorkspaceId == resource.data.workspaceId
        && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
        && isActiveWorkspaceMember(resource.data.workspaceId, userId)
        && request.resource.data.workspaceId == request.resource.data.personalWorkspaceId
        && onlyChanged([
          "workspaceId",
          "personalWorkspaceId",
          "lastRemovedFromWorkspaceId",
          "removedFromWorkspaceAt",
          "updatedAt"
        ]);
    }

    function isSelfJoiningCollaborator(projectId) {
      return isSignedIn()
        && onlyChanged([
          "collaboratorCount",
          "isShared",
          "collaboratorUids",
          "collaboratorEmails",
          "externalGuestUids",
          "accessUpdatedAt",
          "updatedAt"
        ])
        && request.resource.data.collaboratorUids is list
        && request.auth.uid in request.resource.data.collaboratorUids;
    }

    // ─── Global invites ─────────────────────────────────────────────────
    match /invites/{inviteCode} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── CollectionGroup: project collaborators ─────────────────────────
    match /{path=**}/collaborators/{collaboratorId} {
      allow get: if isSignedIn()
        && (
          collaboratorId == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          resource.data.userId == request.auth.uid
        );

                allow list: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
              canReadCurrentTask()
            );


      allow create, update: if isSignedIn();

      allow delete: if isSignedIn();
    }

    // ─── Legacy Root Projects ───────────────────────────────────────────
    match /projects/{projectId} {
      allow get: if isSignedIn() && (
        isProjectOwner(resource.data) ||
        (
          resource.data.workspaceId is string &&
          resource.data.visibility == "workspace" &&
          isActiveWorkspaceMember(resource.data.workspaceId, request.auth.uid)
        ) ||
        isProjectCollaborator(projectId)
      );

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && isProjectOwner(request.resource.data);

      allow update: if isSignedIn() && (
        isProjectOwner(resource.data) ||

        (
          resource.data.workspaceId is string &&
          isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
        ) ||

        (
          isProjectCollaborator(projectId) &&
          onlyChanged([
            "collaboratorCount",
            "isShared",
            "collaboratorUids",
            "collaboratorEmails",
            "externalGuestUids",
            "accessUpdatedAt",
            "updatedAt"
          ])
        ) ||

        isSelfJoiningCollaborator(projectId)
      );

      allow delete: if isSignedIn() && isProjectOwner(resource.data);

      match /invites/{inviteCode} {
        allow read, write: if isSignedIn();
      }

      match /collaborators/{uid} {
        allow read: if isSignedIn() && (
          uid == request.auth.uid ||
          isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
        );

        allow write: if isSignedIn();
      }

      match /tasks/{taskId} {
        allow read, write: if isSignedIn();

        match /{document=**} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // ─── Workspaces ─────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {

      function workspaceOwnerId() {
        return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId;
      }

      function isWorkspaceOwner() {
        return isSignedIn()
          && workspaceOwnerId() == request.auth.uid;
      }

      function isEditingCanonicalOwner(memberId) {
        return memberId == workspaceOwnerId();
      }

      function isWorkspaceProjectVisibleToMe(projectData) {
        return isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId) ||

            (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              && (
                !(projectData.visibility is string) ||
                projectData.visibility == "workspace" ||
                projectData.createdBy == request.auth.uid ||
                projectData.ownerId == request.auth.uid ||
                projectData.uid == request.auth.uid ||
                (
                  projectData.memberIds is list &&
                  request.auth.uid in projectData.memberIds
                ) ||
                (
                  projectData.collaboratorUids is list &&
                  request.auth.uid in projectData.collaboratorUids
                )
              )
            )
          );
      }

      function canManageWorkspaceProject(projectData) {
        return isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId) ||
            projectData.createdBy == request.auth.uid ||
            projectData.ownerId == request.auth.uid ||
            projectData.uid == request.auth.uid ||
            (
              projectData.memberIds is list &&
              request.auth.uid in projectData.memberIds
            )
          );
      }

      // Workspace document
      allow get: if isSignedIn() && (
        isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
        isWorkspaceOwnerOrAdmin(workspaceId)
      );

      allow list: if isSignedIn();

      allow create: if isSignedIn();

      allow update, delete: if isSignedIn()
        && isWorkspaceOwnerOrAdmin(workspaceId);

      // Workspace members
      match /members/{memberId} {
        allow read: if isSignedIn() && (
          memberId == request.auth.uid ||
          isActiveWorkspaceMember(workspaceId, request.auth.uid)
        );

        allow create: if isSignedIn() && (
          (
            memberId == request.auth.uid &&
            request.resource.data.userId == request.auth.uid &&
            (
              request.resource.data.role != "owner" ||
              workspaceOwnerId() == request.auth.uid
            )
          ) ||
          isWorkspaceOwnerOrAdmin(workspaceId)
        );

        allow update: if isSignedIn() && (
          (
            memberId == request.auth.uid &&
            onlyChanged([
              "displayName",
              "photoURL",
              "avatar",
              "avatarColor",
              "lastActive",
              "updatedAt"
            ])
          ) ||

          (
            isWorkspaceOwnerOrAdmin(workspaceId) &&
            (
              !isEditingCanonicalOwner(memberId) ||
              isWorkspaceOwner()
            )
          )
        );

        allow delete: if isSignedIn() && (
          (
            memberId == request.auth.uid &&
            workspaceOwnerId() != request.auth.uid
          ) ||
          (
            isWorkspaceOwnerOrAdmin(workspaceId) &&
            !isEditingCanonicalOwner(memberId)
          )
        );
      }

      // Optional workspace people/profile cache
      match /people/{personId} {
        allow read: if isSignedIn() && (
          personId == request.auth.uid ||
          isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
          isWorkspaceOwnerOrAdmin(workspaceId)
        );

        allow write: if isSignedIn();
      }

      // Workspace invites
      match /invites/{inviteCode} {
        allow read, write: if isSignedIn();
      }

      // Workspace projects
      match /projects/{projectId} {
        allow get: if isWorkspaceProjectVisibleToMe(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid)
          && request.resource.data.workspaceId == workspaceId
          && (
            isWorkspaceOwnerOrAdmin(workspaceId) ||
            request.resource.data.createdBy == request.auth.uid
          );

        allow update: if isSignedIn()
          && canManageWorkspaceProject(resource.data);

        allow delete: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId) ||
            resource.data.ownerId == request.auth.uid ||
            resource.data.createdBy == request.auth.uid
          );

        match /{document=**} {
          allow read, write: if isSignedIn()
            && canManageWorkspaceProject(
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data
            );
        }
      }

      // ─── Workspace tasks + task invite flow ───────────────────────────
      match /tasks/{taskId} {

        function taskSharedWithSignedInEmail(taskData) {
          return isSignedIn()
            && taskData != null
            && taskData.sharedWithEmails is list
            && (
              signedInEmail() in taskData.sharedWithEmails ||
              signedInEmailLower() in taskData.sharedWithEmails
            );
        }

        function canReadTaskData(taskData) {
          return isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
              taskSharedWithSignedInEmail(taskData)
            );
        }

        function canReadCurrentTask() {
          return canReadTaskData(
            get(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)).data
          );
        }

        function shareBelongsToSignedInEmail(shareData) {
          return isSignedIn()
            && request.auth.token.email is string
            && (
              (
                shareData.sharedWithEmail is string &&
                shareData.sharedWithEmail == request.auth.token.email
              ) ||
              (
                shareData.invitedEmail is string &&
                shareData.invitedEmail == request.auth.token.email
              ) ||
              (
                shareData.invitedEmailLower is string &&
                shareData.invitedEmailLower == request.auth.token.email
              ) ||
              (
                shareData.invitedEmailLower is string &&
                shareData.invitedEmailLower == signedInEmailLower()
              )
            );
        }

        function shareOwnerIsSignedInUser(shareData) {
          return isSignedIn()
            && (
              (
                shareData.sharedByUid is string &&
                shareData.sharedByUid == request.auth.uid
              ) ||
              (
                shareData.invitedBy is string &&
                shareData.invitedBy == request.auth.uid
              )
            );
        }

        allow get: if canReadTaskData(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid)
          && request.resource.data.workspaceId == workspaceId;

        allow update, delete: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

                // Task share documents
        match /shares/{shareId} {

          allow get: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
              canReadCurrentTask() ||
              shareBelongsToSignedInEmail(resource.data) ||
              shareOwnerIsSignedInUser(resource.data)
            );

          allow list: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
              canReadCurrentTask()
            );

          allow create: if isSignedIn()
            && isActiveWorkspaceMember(workspaceId, request.auth.uid)
            && (
              request.resource.data.sharedByUid == request.auth.uid ||
              request.resource.data.invitedBy == request.auth.uid
            );

          allow update: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||

              (
                shareBelongsToSignedInEmail(resource.data)
                && resource.data.status == "pending"
                && request.resource.data.status == "active"
                && request.resource.data.acceptedByUid == request.auth.uid
                && request.resource.data.acceptedByEmail == request.auth.token.email
                && onlyChanged([
                  "status",
                  "acceptedBy",
                  "acceptedByUid",
                  "acceptedByEmail",
                  "acceptedAt",
                  "updatedAt"
                ])
              )
            );

          allow delete: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid) ||
              shareOwnerIsSignedInUser(resource.data)
            );
        }


        // Canonical shared task comments.
        // workspaces/{workspaceId}/tasks/{taskId}/comments/{commentId}
        match /comments/{commentId} {
          allow read: if canReadCurrentTask();

          allow create: if canReadCurrentTask()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.taskId == taskId
            && request.resource.data.pinned == false
            && request.resource.data.keys().hasAll([
              "text",
              "authorId",
              "authorName",
              "workspaceId",
              "taskId",
              "createdAt",
              "pinned"
            ])
            && (
              !("attachments" in request.resource.data) ||
              request.resource.data.attachments is list
            );

          allow update: if canReadCurrentTask()
            && (
              onlyChanged(["reactions"]) ||

              (
                resource.data.authorId == request.auth.uid
                && onlyChanged([
                  "text",
                  "editedAt",
                  "editedBy",
                  "editHistory",
                  "mentions",
                  "mentionedUids"
                ])
                && request.resource.data.editedBy == request.auth.uid
                && (
                  resource.data.createdAt == null ||
                  request.time < resource.data.createdAt + duration.value(15, "m")
                )
              ) ||

              (
                onlyChanged([
                  "pinned",
                  "pinnedAt",
                  "pinnedBy"
                ])
                && (
                  (
                    request.resource.data.pinned == true
                    && request.resource.data.pinnedBy == request.auth.uid
                  ) ||
                  (
                    request.resource.data.pinned == false
                    && request.resource.data.pinnedBy == ""
                  )
                )
              )
            );

          allow delete: if canReadCurrentTask()
            && (
              resource.data.authorId == request.auth.uid ||
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
            );
        }

        // Task likes
        match /likes/{likeId} {
          allow read: if canReadCurrentTask();

          allow create: if canReadCurrentTask()
            && request.auth.uid == likeId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.taskId == taskId;

          allow update: if canReadCurrentTask()
            && request.auth.uid == likeId
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.taskId == taskId;

          allow delete: if canReadCurrentTask()
            && request.auth.uid == likeId
            && resource.data.uid == request.auth.uid
            && resource.data.workspaceId == workspaceId
            && resource.data.taskId == taskId;
        }

        match /{document=**} {
          allow read, write: if isSignedIn()
            && isActiveWorkspaceMember(workspaceId, request.auth.uid);
        }
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    // ─── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSelfUid(userId);

      allow update: if isSelfUid(userId) || canWorkspaceAdminRemoveUser(userId);

      allow delete: if isSelfUid(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelfUid(userId);

        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid == userId
          && request.resource.data.keys().hasAll([
            "type",
            "senderUid",
            "recipientUid",
            "projectId",
            "createdAt"
          ]);
      }

      // Legacy user-scoped projects
      match /projects/{projectId} {
        allow read, write: if isSelfUid(userId);

        match /{document=**} {
          allow read, write: if isSelfUid(userId);
        }
      }

      // User-scoped tasks.
      // AcceptTaskInvitePage copies accepted shared tasks here:
      // users/{invitedUserId}/tasks/{taskId}
      match /tasks/{taskId} {
        allow read: if isSignedIn()
          && userId == request.auth.uid;

        allow create, update, delete: if isSignedIn()
          && userId == request.auth.uid;

        match /comments/{commentId} {
          allow read: if isSignedIn()
            && userId == request.auth.uid;

          allow create: if isSignedIn()
            && userId == request.auth.uid
            && request.resource.data.authorId == request.auth.uid;

          allow delete: if isSignedIn()
            && userId == request.auth.uid
            && (
              resource.data.authorId == request.auth.uid ||
              userId == request.auth.uid
            );

          allow update: if isSignedIn()
            && userId == request.auth.uid
            && (
              (
                resource.data.authorId == request.auth.uid
                && onlyChanged([
                  "text",
                  "editedAt",
                  "editHistory",
                  "mentions",
                  "mentionedUids"
                ])
                && (
                  resource.data.createdAt == null ||
                  request.time < resource.data.createdAt + duration.value(15, "m")
                )
              )
              ||
              (
                onlyChanged(["deliveredTo"])
                && request.resource.data.deliveredTo.hasAll(resource.data.deliveredTo)
                && request.resource.data.deliveredTo
                  .removeAll(resource.data.deliveredTo)
                  .hasOnly([request.auth.uid])
              )
              ||
              (
                onlyChanged(["readBy"])
                && request.resource.data.readBy.hasAll(resource.data.readBy)
                && request.resource.data.readBy
                  .removeAll(resource.data.readBy)
                  .hasOnly([request.auth.uid])
              )
              ||
              onlyChanged(["reactions"])
            );
        }

        match /{document=**} {
          allow read, write: if isSignedIn()
            && userId == request.auth.uid;
        }
      }

      match /{subcollection}/{docId} {
        allow read, write, create, delete: if isSelfUid(userId);
      }
    }
  }
}
