rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelfUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function signedInEmailLower() {
      return isSignedIn() && request.auth.token.email_lowercase is string
        ? request.auth.token.email_lowercase
        : signedInEmail();
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyChanged(allowed) {
      return changedKeys().hasOnly(allowed);
    }

    function isPersonalWorkspaceId(workspaceId, uid) {
      return workspaceId == "personal_" + uid;
    }

    function isWorkspaceOwnerByDoc(workspaceId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == uid;
    }

    function hasWorkspaceMemberDoc(workspaceId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid));
    }

    function memberDocMatchesUserAndWorkspace(workspaceId, uid) {
      return hasWorkspaceMemberDoc(workspaceId, uid)
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.status == "active"
        && (
          !("workspaceId" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data)
          || get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.workspaceId == workspaceId
        )
        && (
          !("uid" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data)
          || get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.uid == uid
        )
        && (
          !("userId" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data)
          || get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.userId == uid
        );
    }

    function memberDocHasTrustedSource(workspaceId, uid) {
      return hasWorkspaceMemberDoc(workspaceId, uid)
        && (
          isWorkspaceOwnerByDoc(workspaceId, uid)
          || get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data.role == "owner"
          || "inviteCode" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "acceptedInviteCode" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "code" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "invitedBy" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "invitedByUid" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "addedBy" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
          || "createdBy" in get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid)).data
        );
    }

    function isTrustedActiveWorkspaceMemberDoc(workspaceId, uid) {
      return memberDocMatchesUserAndWorkspace(workspaceId, uid)
        && memberDocHasTrustedSource(workspaceId, uid);
    }

    function isActiveWorkspaceMember(workspaceId, uid) {
      return isSignedIn()
        && (
          isWorkspaceOwnerByDoc(workspaceId, uid)
          || isTrustedActiveWorkspaceMemberDoc(workspaceId, uid)
        );
    }

    function isWorkspaceOwnerOrAdmin(workspaceId) {
      return isSignedIn()
        && (
          isWorkspaceOwnerByDoc(workspaceId, request.auth.uid)
          || (
            isTrustedActiveWorkspaceMemberDoc(workspaceId, request.auth.uid)
            && (
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == "owner"
              || get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == "admin"
            )
          )
        );
    }

    function inviteStatusAllowsJoin(inviteData) {
      return !("status" in inviteData)
        || inviteData.status in ["pending", "active", "accepted", "invited"];
    }

    function hasWorkspaceInviteDoc(workspaceId, inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode));
    }

    function hasGlobalInviteDoc(inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && exists(/databases/$(database)/documents/invites/$(inviteCode));
    }

    function hasValidWorkspaceInvite(workspaceId, inviteCode) {
      return inviteCode is string
        && inviteCode != ""
        && (
          (
            hasWorkspaceInviteDoc(workspaceId, inviteCode)
            && get(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode)).data.workspaceId == workspaceId
            && inviteStatusAllowsJoin(get(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(inviteCode)).data)
          )
          || (
            hasGlobalInviteDoc(inviteCode)
            && get(/databases/$(database)/documents/invites/$(inviteCode)).data.workspaceId == workspaceId
            && inviteStatusAllowsJoin(get(/databases/$(database)/documents/invites/$(inviteCode)).data)
          )
        );
    }

    function inviteEmailMatchesSignedIn(inviteData) {
      return isSignedIn()
        && (
          (
            inviteData.email is string
            && inviteData.email == signedInEmail()
          )
          || (
            inviteData.emailLower is string
            && inviteData.emailLower == signedInEmailLower()
          )
          || (
            inviteData.email_lowercase is string
            && inviteData.email_lowercase == signedInEmailLower()
          )
          || (
            inviteData.invitedEmail is string
            && inviteData.invitedEmail == signedInEmail()
          )
          || (
            inviteData.invitedEmailLower is string
            && inviteData.invitedEmailLower == signedInEmailLower()
          )
          || (
            inviteData.acceptedByEmail is string
            && inviteData.acceptedByEmail == signedInEmail()
          )
          || (
            inviteData.acceptedByEmailLower is string
            && inviteData.acceptedByEmailLower == signedInEmailLower()
          )
          || (
            inviteData.acceptedByUid is string
            && inviteData.acceptedByUid == request.auth.uid
          )
          || (
            inviteData.acceptedBy is string
            && inviteData.acceptedBy == request.auth.uid
          )
        );
    }

    function inviteAcceptUpdateAllowed() {
      return isSignedIn()
        && (
          inviteEmailMatchesSignedIn(resource.data)
          || inviteEmailMatchesSignedIn(request.resource.data)
          || request.resource.data.acceptedByUid == request.auth.uid
          || request.resource.data.acceptedBy == request.auth.uid
        );
    }

    function isProjectOwner(projectData) {
      return isSignedIn()
        && (
          (projectData.ownerId is string && projectData.ownerId == request.auth.uid)
          || (projectData.uid is string && projectData.uid == request.auth.uid)
          || (projectData.createdBy is string && projectData.createdBy == request.auth.uid)
        );
    }

    function isRootProjectCollaborator(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
    }

    function rootProjectVisibleToMe(projectData, projectId) {
      return isSignedIn()
        && (
          isProjectOwner(projectData)
          || isRootProjectCollaborator(projectId)
          || (
            projectData.workspaceId is string
            && projectData.visibility == "workspace"
            && isActiveWorkspaceMember(projectData.workspaceId, request.auth.uid)
          )
        );
    }

    function canWorkspaceAdminRemoveUser(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && resource.data.workspaceId is string
        && request.resource.data.lastRemovedFromWorkspaceId == resource.data.workspaceId
        && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
        && isActiveWorkspaceMember(resource.data.workspaceId, userId)
        && request.resource.data.workspaceId == request.resource.data.personalWorkspaceId
        && onlyChanged([
          "workspaceId",
          "personalWorkspaceId",
          "lastRemovedFromWorkspaceId",
          "removedFromWorkspaceAt",
          "updatedAt"
        ]);
    }

        // ─── Global Invites ─────────────────────────────────────────────────
    match /invites/{inviteCode} {
      allow read: if true;

      allow create: if isSignedIn();

      allow update: if isSignedIn()
        && (
          inviteAcceptUpdateAllowed()
          || request.resource.data.acceptedByUid == request.auth.uid
          || request.resource.data.acceptedBy == request.auth.uid
          || (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
        );

      allow delete: if isSignedIn()
        && (
          (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
          || resource.data.invitedBy == request.auth.uid
          || resource.data.invitedByUid == request.auth.uid
        );
    }


    // ─── Collection Group: Collaborators ────────────────────────────────
    match /{path=**}/collaborators/{collaboratorId} {
      allow get: if isSignedIn()
        && (
          collaboratorId == request.auth.uid
          || resource.data.uid == request.auth.uid
          || resource.data.userId == request.auth.uid
        );

      allow list: if isSignedIn();

      allow create, update, delete: if isSignedIn();
    }

    // ─── Legacy Root Projects ───────────────────────────────────────────
    match /projects/{projectId} {
      allow get: if rootProjectVisibleToMe(resource.data, projectId);

      allow list: if rootProjectVisibleToMe(resource.data, projectId);

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (
          !("ownerId" in request.resource.data)
          || request.resource.data.ownerId == request.auth.uid
        )
        && (
          !("uid" in request.resource.data)
          || request.resource.data.uid == request.auth.uid
        );

      allow update: if isSignedIn()
        && (
          isProjectOwner(resource.data)
          || isRootProjectCollaborator(projectId)
          || (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
        );

      allow delete: if isSignedIn()
        && (
          isProjectOwner(resource.data)
          || (
            resource.data.workspaceId is string
            && isWorkspaceOwnerOrAdmin(resource.data.workspaceId)
          )
        );

      match /invites/{inviteCode} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /collaborators/{uid} {
        allow read: if isSignedIn()
          && (
            uid == request.auth.uid
            || isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
          );

        allow write: if isSignedIn()
          && (
            uid == request.auth.uid
            || isProjectOwner(get(/databases/$(database)/documents/projects/$(projectId)).data)
          );
      }

      match /tasks/{taskId} {
        allow read, write: if isSignedIn()
          && rootProjectVisibleToMe(
            get(/databases/$(database)/documents/projects/$(projectId)).data,
            projectId
          );

        match /{document=**} {
          allow read, write: if isSignedIn()
            && rootProjectVisibleToMe(
              get(/databases/$(database)/documents/projects/$(projectId)).data,
              projectId
            );
        }
      }
    }

    // ─── Workspaces ─────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      function workspaceOwnerId() {
        return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId;
      }

      function isWorkspaceOwner() {
        return isSignedIn() && workspaceOwnerId() == request.auth.uid;
      }

      function isEditingCanonicalOwner(memberId) {
        return memberId == workspaceOwnerId();
      }

      function workspaceProjectVisibleToMe(projectData) {
        return isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              && (
                !("visibility" in projectData)
                || projectData.visibility == "workspace"
                || projectData.visibility == "public"
                || projectData.createdBy == request.auth.uid
                || projectData.ownerId == request.auth.uid
                || projectData.uid == request.auth.uid
                || (
                  projectData.memberIds is list
                  && request.auth.uid in projectData.memberIds
                )
                || (
                  projectData.collaboratorUids is list
                  && request.auth.uid in projectData.collaboratorUids
                )
              )
            )
          );
      }

      function canManageWorkspaceProject(projectData) {
        return isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || projectData.createdBy == request.auth.uid
            || projectData.ownerId == request.auth.uid
            || projectData.uid == request.auth.uid
            || (
              projectData.memberIds is list
              && request.auth.uid in projectData.memberIds
            )
            || (
              projectData.collaboratorUids is list
              && request.auth.uid in projectData.collaboratorUids
            )
          );
      }

      // Workspace document
      allow get: if isSignedIn()
        && (
          isActiveWorkspaceMember(workspaceId, request.auth.uid)
          || hasWorkspaceMemberDoc(workspaceId, request.auth.uid)
          || isPersonalWorkspaceId(workspaceId, request.auth.uid)
          || resource.data.ownerId == request.auth.uid
        );

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && (
          request.resource.data.workspaceId == workspaceId
          || request.resource.data.id == workspaceId
        );

      allow update: if isSignedIn()
        && (
          isWorkspaceOwnerOrAdmin(workspaceId)
          || (
            isPersonalWorkspaceId(workspaceId, request.auth.uid)
            && resource.data.ownerId == request.auth.uid
          )
          || (
            hasWorkspaceMemberDoc(workspaceId, request.auth.uid)
            && onlyChanged([
              "memberCount",
              "usedSeats",
              "updatedAt",
              "lastJoinedAt"
            ])
          )
        );

      allow delete: if isSignedIn()
        && isWorkspaceOwnerByDoc(workspaceId, request.auth.uid);

           // Workspace members
      match /members/{memberId} {
        function isSelfMemberWrite() {
          return isSignedIn()
            && memberId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.status == "active"
            && (
              request.resource.data.uid == request.auth.uid
              || request.resource.data.userId == request.auth.uid
            );
        }

        function selfHasInviteCode() {
          return (
            hasValidWorkspaceInvite(workspaceId, request.resource.data.inviteCode)
            || hasValidWorkspaceInvite(workspaceId, request.resource.data.acceptedInviteCode)
            || hasValidWorkspaceInvite(workspaceId, request.resource.data.code)
          );
        }

        function canSelfJoinWorkspace() {
          return isSelfMemberWrite()
            && request.resource.data.role in ["admin", "member", "viewer"]
            && selfHasInviteCode();
        }

        function canSelfCreatePersonalOwner() {
          return isSelfMemberWrite()
            && isPersonalWorkspaceId(workspaceId, request.auth.uid)
            && request.resource.data.role == "owner";
        }

        allow get: if isSignedIn()
          && (
            memberId == request.auth.uid
            || isActiveWorkspaceMember(workspaceId, request.auth.uid)
            || isWorkspaceOwnerOrAdmin(workspaceId)
          );

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || canSelfCreatePersonalOwner()
            || canSelfJoinWorkspace()
          );

        allow update: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || canSelfJoinWorkspace()
            || (
              memberId == request.auth.uid
              && onlyChanged([
                "displayName",
                "name",
                "email",
                "emailLower",
                "email_lowercase",
                "photoURL",
                "avatar",
                "avatarColor",
                "avatarUrl",
                "avatarURL",
                "googlePhotoURL",
                "lastActive",
                "updatedAt"
              ])
            )
          );

        allow delete: if isSignedIn()
          && (
            (
              memberId == request.auth.uid
              && workspaceOwnerId() != request.auth.uid
            )
            || (
              isWorkspaceOwnerOrAdmin(workspaceId)
              && !isEditingCanonicalOwner(memberId)
            )
          );
      }

      // Workspace people/profile cache
      match /people/{personId} {
        allow read: if isSignedIn()
          && (
            personId == request.auth.uid
            || isActiveWorkspaceMember(workspaceId, request.auth.uid)
            || isWorkspaceOwnerOrAdmin(workspaceId)
          );

        allow write: if isSignedIn()
          && (
            personId == request.auth.uid
            || isWorkspaceOwnerOrAdmin(workspaceId)
          );
      }

            // Workspace invites
      match /invites/{inviteCode} {
        allow read: if true;

        allow create: if isSignedIn()
          && isWorkspaceOwnerOrAdmin(workspaceId);

        allow update: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || request.resource.data.acceptedByUid == request.auth.uid
            || request.resource.data.acceptedBy == request.auth.uid
            || (
              resource.data.workspaceId == workspaceId
              && inviteAcceptUpdateAllowed()
            )
          );

        allow delete: if isSignedIn()
          && isWorkspaceOwnerOrAdmin(workspaceId);
      }

      // Workspace projects
      match /projects/{projectId} {
        allow get: if workspaceProjectVisibleToMe(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.createdBy == request.auth.uid
          && (
            !("ownerId" in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid
          )
          && (
            !("uid" in request.resource.data)
            || request.resource.data.uid == request.auth.uid
          )
          && (
            isActiveWorkspaceMember(workspaceId, request.auth.uid)
            || (
              isPersonalWorkspaceId(workspaceId, request.auth.uid)
              && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
              && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid
            )
          );

        allow update: if isSignedIn()
          && canManageWorkspaceProject(resource.data);

        allow delete: if isSignedIn()
          && (
            isWorkspaceOwnerOrAdmin(workspaceId)
            || resource.data.ownerId == request.auth.uid
            || resource.data.createdBy == request.auth.uid
            || resource.data.uid == request.auth.uid
          );

        match /{document=**} {
          allow read: if isSignedIn()
            && workspaceProjectVisibleToMe(
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data
            );

          allow write: if isSignedIn()
            && canManageWorkspaceProject(
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data
            );
        }
      }

      // Workspace tasks
      match /tasks/{taskId} {
        function taskSharedWithSignedInEmail(taskData) {
          return isSignedIn()
            && taskData != null
            && taskData.sharedWithEmails is list
            && (
              signedInEmail() in taskData.sharedWithEmails
              || signedInEmailLower() in taskData.sharedWithEmails
            );
        }

        function canReadTaskData(taskData) {
          return isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || taskSharedWithSignedInEmail(taskData)
            );
        }

        function canReadCurrentTask() {
          return canReadTaskData(
            get(/databases/$(database)/documents/workspaces/$(workspaceId)/tasks/$(taskId)).data
          );
        }

        function shareBelongsToSignedInEmail(shareData) {
          return isSignedIn()
            && request.auth.token.email is string
            && (
              shareData.sharedWithEmail == request.auth.token.email
              || shareData.invitedEmail == request.auth.token.email
              || shareData.invitedEmailLower == request.auth.token.email
              || shareData.invitedEmailLower == signedInEmailLower()
            );
        }

        function shareOwnerIsSignedInUser(shareData) {
          return isSignedIn()
            && (
              shareData.sharedByUid == request.auth.uid
              || shareData.invitedBy == request.auth.uid
            );
        }

        allow get: if canReadTaskData(resource.data);

        allow list: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        allow create: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid)
          && request.resource.data.workspaceId == workspaceId;

        allow update, delete: if isSignedIn()
          && isActiveWorkspaceMember(workspaceId, request.auth.uid);

        match /shares/{shareId} {
          allow get: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || canReadCurrentTask()
              || shareBelongsToSignedInEmail(resource.data)
              || shareOwnerIsSignedInUser(resource.data)
            );

          allow list: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || canReadCurrentTask()
            );

          allow create: if isSignedIn()
            && isActiveWorkspaceMember(workspaceId, request.auth.uid)
            && (
              request.resource.data.sharedByUid == request.auth.uid
              || request.resource.data.invitedBy == request.auth.uid
            );

          allow update: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || (
                shareBelongsToSignedInEmail(resource.data)
                && resource.data.status == "pending"
                && request.resource.data.status == "active"
                && request.resource.data.acceptedByUid == request.auth.uid
                && request.resource.data.acceptedByEmail == request.auth.token.email
                && onlyChanged([
                  "status",
                  "acceptedBy",
                  "acceptedByUid",
                  "acceptedByEmail",
                  "acceptedAt",
                  "updatedAt"
                ])
              )
            );

          allow delete: if isSignedIn()
            && (
              isActiveWorkspaceMember(workspaceId, request.auth.uid)
              || shareOwnerIsSignedInUser(resource.data)
            );
        }

        match /comments/{commentId} {
          allow read: if canReadCurrentTask();

          allow create: if canReadCurrentTask()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.workspaceId == workspaceId
            && request.resource.data.taskId == taskId;

          allow update: if canReadCurrentTask()
            && (
              resource.data.authorId == request.auth.uid
              || isWorkspaceOwnerOrAdmin(workspaceId)
            );

          allow delete: if canReadCurrentTask()
            && (
              resource.data.authorId == request.auth.uid
              || isWorkspaceOwnerOrAdmin(workspaceId)
            );
        }

        match /likes/{likeId} {
          allow read: if canReadCurrentTask();

          allow create, update, delete: if canReadCurrentTask()
            && request.auth.uid == likeId;
        }

        match /{document=**} {
          allow read, write: if isSignedIn()
            && isActiveWorkspaceMember(workspaceId, request.auth.uid);
        }
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    // ─── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSelfUid(userId);

      allow update: if isSelfUid(userId)
        || canWorkspaceAdminRemoveUser(userId);

      allow delete: if isSelfUid(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelfUid(userId);

        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid == userId;
      }

      match /projects/{projectId} {
        allow read, write: if isSelfUid(userId);

        match /{document=**} {
          allow read, write: if isSelfUid(userId);
        }
      }

      match /tasks/{taskId} {
        allow read, create, update, delete: if isSelfUid(userId);

        match /comments/{commentId} {
          allow read, create, update, delete: if isSelfUid(userId);
        }

        match /{document=**} {
          allow read, write: if isSelfUid(userId);
        }
      }

      match /{subcollection}/{docId} {
        allow read, write: if isSelfUid(userId);
      }
    }
  }
}
